# URL base do API Gateway (padrão: porta 3080)
VITE_GATEWAY_URL=http://localhost:3080

# Senha para proteger a rota /admin (opcional; sem valor = acesso livre)
VITE_ADMIN_PASSWORD=

# Token para bloquear /loja em modo preview (opcional; gere com: npm run preview:token)
VITE_PREVIEW_TOKEN=

# Duração da sessão de preview em horas (padrão: 8)
VITE_PREVIEW_HOURS=8
